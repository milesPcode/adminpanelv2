const express = require('express');
const net = require('net');
const zlib = require('zlib');
const app = express();
const PORT = 3000;
const PORTS = [8392,8393,8394,8395,8396,8397];
app.use(express.json());
app.use((req,res,next)=>{
  res.setHeader('Access-Control-Allow-Origin','*');
  res.setHeader('Access-Control-Allow-Headers','Content-Type');
  res.setHeader('Access-Control-Allow-Methods','POST,GET,OPTIONS');
  if(req.method==='OPTIONS') return res.sendStatus(200);
  next();
});
function trySend(script, port) {
  return new Promise((resolve) => {
    zlib.deflate(script, (err, compressed) => {
      if(err) return resolve({success:false, message:`Compression failed: ${err.message}`});
      const socket = new net.Socket();
      socket.setTimeout(2000);
      socket.connect(port,'127.0.0.1',()=>{
        socket.write(compressed);
        socket.end();
        resolve({success:true, message:`Sent ${compressed.length} bytes to port ${port}`});
      });
      socket.on('error',(e)=>{ socket.destroy(); resolve({success:false, message:e.message}); });
      socket.on('timeout',()=>{ socket.destroy(); resolve({success:false, message:`Timeout on port ${port}`}); });
    });
  });
}
app.post('/execute', async (req,res)=>{
  const {script, port} = req.body;
  if(!script) return res.json({success:false, message:'No script provided'});
  if(port==='ALL'){
    for(const p of PORTS){
      const r = await trySend(script, p);
      if(r.success) return res.json({success:true, port:p, message:r.message});
    }
    return res.json({success:false, message:'All ports failed'});
  }
  const p = parseInt(port,10);
  const r = await trySend(script, p);
  return res.json({...r, port:p});
});
app.get('/ping',(req,res)=>res.json({status:'ok'}));
app.listen(PORT,()=>console.log(`Backend running on port ${PORT}`));
