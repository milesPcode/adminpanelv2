const BACKEND_URL = 'http://localhost:3000';
require.config({ paths: { vs: 'https://cdnjs.cloudflare.com/ajax/libs/monaco-editor/0.44.0/min/vs' } });
let editor;
require(['vs/editor/editor.main'], function() {
  editor = monaco.editor.create(document.getElementById('editor-container'), {
    value: '-- RAT Executor v10.0\n-- Write your Lua script here\n\nprint("Hello from RAT Executor!")\n',
    language: 'lua', theme: 'vs-dark', fontSize: 13,
    fontFamily: '"Courier New", Courier, monospace',
    minimap: { enabled: false }, scrollBeyondLastLine: false,
    lineNumbers: 'on', automaticLayout: true, padding: { top: 10 }
  });
  monaco.editor.defineTheme('rat-theme', {
    base: 'vs-dark', inherit: true,
    rules: [
      { token: 'comment', foreground: '1a6a1a' },
      { token: 'string', foreground: '44cc44' },
      { token: 'keyword', foreground: '00ff41' },
      { token: 'number', foreground: 'aaff88' },
      { token: '', foreground: '00ee33' }
    ],
    colors: {
      'editor.background': '#030b03', 'editor.foreground': '#00ff41',
      'editor.lineHighlightBackground': '#0a1f0a',
      'editorCursor.foreground': '#00ff41',
      'editorLineNumber.foreground': '#1a4a1a',
      'editor.selectionBackground': '#003300'
    }
  });
  monaco.editor.setTheme('rat-theme');
  log('Editor ready.', 'muted');
});
function log(message, type = 'info') {
  const output = document.getElementById('console-output');
  const line = document.createElement('div');
  const now = new Date().toLocaleTimeString('en-US', { hour12: false });
  line.className = `log-${type}`;
  line.textContent = `[${now}] ${message}`;
  output.appendChild(line);
  output.scrollTop = output.scrollHeight;
}
function setAttachStatus(attached, label) {
  const badge = document.getElementById('attach-badge');
  const status = document.getElementById('connection-status');
  badge.textContent = label;
  if (attached) { badge.classList.add('ok'); status.textContent = '● ' + label; status.classList.add('attached'); }
  else { badge.classList.remove('ok'); status.textContent = '● ' + label; status.classList.remove('attached'); }
}
document.getElementById('btn-execute').addEventListener('click', async () => {
  if (!editor) { log('Editor not ready.', 'warn'); return; }
  const script = editor.getValue().trim();
  if (!script) { log('Editor is empty.', 'warn'); return; }
  const port = document.getElementById('port-select').value;
  log(`Sending to port ${port}...`, 'info');
  setAttachStatus(false, 'SENDING...');
  try {
    const res = await fetch(`${BACKEND_URL}/execute`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ script, port })
    });
    const data = await res.json();
    if (data.success) { log(`SUCCESS — port ${data.port}: ${data.message}`, 'success'); setAttachStatus(true, `ATTACHED :${data.port}`); }
    else { log(`FAILED — ${data.message}`, 'error'); setAttachStatus(false, 'NOT ATTACHED'); }
  } catch(err) {
    log(`Cannot reach backend. Is server.js running? ${err.message}`, 'error');
    setAttachStatus(false, 'NOT ATTACHED');
  }
});
document.getElementById('btn-inject').addEventListener('click', () => document.getElementById('btn-execute').click());
document.getElementById('btn-clear').addEventListener('click', () => { if (editor) { editor.setValue(''); log('Cleared.', 'muted'); } });
document.getElementById('btn-clear-console').addEventListener('click', () => document.getElementById('console-output').innerHTML = '');
document.getElementById('btn-save').addEventListener('click', () => {
  if (!editor) return;
  const blob = new Blob([editor.getValue()], { type: 'text/plain' });
  const a = document.createElement('a'); a.href = URL.createObjectURL(blob); a.download = 'script.lua'; a.click();
  log('Saved as script.lua', 'success');
});
document.getElementById('btn-open').addEventListener('click', () => {
  const input = document.createElement('input'); input.type = 'file'; input.accept = '.lua,.txt';
  input.onchange = (e) => {
    const file = e.target.files[0]; if (!file || !editor) return;
    const reader = new FileReader();
    reader.onload = (ev) => { editor.setValue(ev.target.result); log(`Loaded: ${file.name}`, 'success'); };
    reader.readAsText(file);
  };
  input.click();
});
document.querySelectorAll('.tab').forEach(t => t.addEventListener('click', () => { document.querySelectorAll('.tab').forEach(x => x.classList.remove('active')); t.classList.add('active'); }));
document.querySelectorAll('.sidebar-item').forEach(i => i.addEventListener('click', () => { document.querySelectorAll('.sidebar-item').forEach(x => x.classList.remove('active')); i.classList.add('active'); }));
SCRIPTJS
